# PwC GenAI Shared Service config
GENAI_BASE_URL=https://genai-sharedservice-emea.pwc.com
GENAI_API_KEY=sk-your-key-here
GENAI_API_VERSION=
# HTML/code generation — the strong model (your exact Opus id), e.g. claude-opus-4-8.
GENAI_LLM_MODEL=bedrock.anthropic.claude-opus-4

# Conversational agent chat + lightweight QA — a cheap, fast streaming model (Haiku).
GENAI_CHAT_MODEL=bedrock.anthropic.claude-haiku-4-5

# Set to true to serve canned streamed HTML without calling GenAI (offline demo).
USE_MOCK_AI=false

# Access tokens, enforced server-side via the X-Studio-Token header.
#   STUDIO_PASSWORD — participants: unlocks LLM calls + gallery submit.
#   WALL_PASSWORD   — facilitator host secret: clear gallery / reset session.
# Set all three empty to disable auth (e.g. local mock runs).
#   ADMIN_PASSWORD  — facilitator: the /admin screen that steers the training
#                     (which labs are in it, lock/unlock live). Highest privilege.
STUDIO_PASSWORD=PwCVibeCoding2026
WALL_PASSWORD=PwCVibeWall2026
ADMIN_PASSWORD=PwCVibeAdmin2026

# Max concurrent GenAI calls across all users on this process (shared-key throttle).
# Raise/lower based on your key's rate limits. Excess calls queue rather than error.
GENAI_MAX_CONCURRENCY=8

# Max tokens the model may emit per call. Keep generous so full single-file apps
# don't get truncated half-written (which makes the preview app non-functional).
GENAI_MAX_OUTPUT_TOKENS=16000

# Shared database (Neon / Vercel Postgres). REQUIRED on Vercel: serverless runs
# many instances, so the gallery/stage/epoch must live in one shared store — without
# it the wall flickers and submissions get lost (each instance has its own memory).
# Use the POOLED connection string. Leave empty for local dev (falls back to a JSON
# file under backend/data). DB_SSL auto-detects (require for remote, disable for localhost).
DATABASE_URL=
# DB_SSL=require   # override if needed: "require" or "disable"
